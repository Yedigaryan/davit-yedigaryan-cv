# Contact form delivery — the static build POSTs JSON to a third-party
# form-relay service (no server-side code here). Any service that accepts
# a JSON POST and returns 2xx works: Formspree, FormSubmit (ajax),
# Web3Forms, Getform, etc. If unset, the form falls back to FormSubmit's
# ajax endpoint pointing at davit@yedigaryan.pro — works without an
# account, but the FIRST submission triggers a one-time confirmation
# email that must be clicked before deliveries start flowing.
NEXT_PUBLIC_CONTACT_ENDPOINT="https://formsubmit.co/ajax/davit@yedigaryan.pro"

# LLM chat widget — point at the gateway service in this repo (or any
# OpenAI-compatible backend you control). The default below assumes you've
# deployed `gateway/` to Render via the bundled render.yaml; see
# DEPLOY-RENDER-GATEWAY.md for the full setup.

# Required: full URL of the chat completions endpoint.
NEXT_PUBLIC_CHAT_API_URL="https://cv-llm-gateway.onrender.com/v1/chat/completions"

# Bearer token shared with the gateway's $LLM_API_TOKEN.
# NOTE: any NEXT_PUBLIC_ value ships to every visitor's browser. That's
# acceptable here because the token only authorizes use of YOUR laptop's
# compute (Ollama on the M1 Pro). For provider-issued keys (OpenAI,
# Anthropic) keep them server-side and proxy through a backend instead.
NEXT_PUBLIC_CHAT_API_KEY=""

# Model identifier forwarded to Ollama. Must match a tag you've pulled
# locally (`ollama list` on the M1 Pro). Swap freely between gemma3 /
# gemma4 / qwen2.5 / llama3.2 — the gateway is model-agnostic.
NEXT_PUBLIC_CHAT_MODEL="gemma3"

# Enable Server-Sent-Events streaming. Ollama's /v1/chat/completions
# supports streaming when `stream: true` is in the request body.
NEXT_PUBLIC_CHAT_STREAMING="true"
